{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Saira Terminal",
  "version": "0.1.0",
  "identifier": "com.saira.terminal",
  "build": {
    "frontendDist": "frontend"
  },
  "app": {
    "windows": [
      {
        "title": "Saira Terminal",
        "url": "index.html",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../app": "app",
      "../requirements.txt": "requirements.txt",
      "../run.bat": "run.bat",
      "../tickers_allowlist.txt": "tickers_allowlist.txt",
      "../lightweight-charts.standalone.production.js": "lightweight-charts.standalone.production.js"
    }
  }
}
